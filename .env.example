# =============================================================================
# SAMAAYA — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local (see .gitignore).
# NEXT_PUBLIC_* are exposed to the browser; everything else is server-only.
# =============================================================================

# --- Supabase -----------------------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# DANGER: full DB access, bypasses RLS. Server-only. Never prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Razorpay (Prompt 2.3) ----------------------------------------------------
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Resend (Prompt 0.3 / 2.4) ------------------------------------------------
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=SAMAAYA <orders@yourdomain.com>

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
